{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build Raylib",
      "type": "shell",
      "command": "gcc",
      "args": [
        "src/main.c",
        "-o",
        "src/main.exe",
        "-lraylib",
        "-lopengl32",
        "-lgdi32",
        "-lwinmm"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}